function fizzbuzz(max) {
    num = 1
    while (num <= max) {
        output = ""
        if (num % 3 == 0){
            output = output + "Fizz"
        }
        if (num % 5 == 0){
            output = output + 'Buzz'
        }
        if (len(output) == 0){
            output = str(num)
        }
        print(output)
        num = num + 1
    }
}
fizzbuzz(100)
